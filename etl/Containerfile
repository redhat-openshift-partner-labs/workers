FROM python:3.12-slim

WORKDIR /app

# Install deps first for layer caching
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy worker source files
COPY worker.py transform.py schema.py schema_registry.py envelope.py config.py __init__.py ./

# OpenShift runs with arbitrary UID - ensure files are world-readable
# and /app directory is accessible
RUN chmod -R a+rX /app

# Run as non-root (OpenShift assigns arbitrary UID at runtime)
USER 1001

ENTRYPOINT ["python", "-m", "worker"]
