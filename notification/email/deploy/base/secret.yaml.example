apiVersion: v1
kind: Secret
metadata:
  name: smtp-credentials
  labels:
    app: opl-email-service
type: Opaque
stringData:
  # For Mailhog testing (no credentials needed - leave empty)
  # For production SMTP, replace with actual credentials:
  #   Gmail: username = your-email@gmail.com, password = app-password
  #   SendGrid: username = apikey, password = your-api-key
  username: ""
  password: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  labels:
    app: opl-email-service
type: Opaque
stringData:
  # RabbitMQ connection settings
  # CHANGE_ME: Replace with your actual RabbitMQ configuration
  host: "rabbitmq.rabbitmq.svc.cluster.local"
  port: "5672"
  user: "RABBITMQ_USER"
  pass: "RABBITMQ_PASSWORD"
  vhost: "/"
