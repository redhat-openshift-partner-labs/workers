FROM python:3.12-slim

WORKDIR /app

# Install deps first for layer caching
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy worker source files as a notification package
COPY *.py ./notification/
COPY templates/ ./notification/templates/

# OpenShift runs with arbitrary UID - ensure files are world-readable
RUN chmod -R a+rX /app

# Run as non-root (OpenShift assigns arbitrary UID at runtime)
USER 1001

ENTRYPOINT ["python", "-m", "notification"]
